  "fix_code": "import pandas as pd\nimport numpy as np\nimport re\n\ndef apply_fix(df):\n    df = df.copy()\n    \n    # Fix null values in 'email' column\n    if 'email' in df.columns:\n        df['email'] = df['email'].fillna(df['email'].mode()[0])\n    \n    # Fix regex mismatch in 'email' column\n    if 'email' in df.columns:\n        df['email'] = df['email'].apply(lambda x: x if re.match('^[\\w.-]+@[\\w.-]+\\.\\w+$', x) else None)\n    \n    # Fix null values in 'signup_date' column\n    if 'signup_date' in df.columns:\n        df['signup_date'] = pd.to_datetime(df['signup_date'], errors='coerce').fillna(df['signup_date'].mode()[0])\n    \n    # Fix outliers in 'age' column\n    if 'age' in df.columns:\n        q1 = df['age'].quantile(0.25)\n        q3 = df['age'].quantile(0.75)\n        iqr = q3 - q1\n        lower_fence = q1 - 1.5 * iqr\n        upper_fence = q3 + 1.5 * iqr\n        df['age'] = df['age'].apply(lambda x: lower_fence if x < lower_fence else upper_fence if x > upper_fence else x)\n    \n    # Fix outliers in 'signup_date' column\n    if 'signup_date' in df.columns:\n        mean = df['signup_date'].mean()\n        std = df['signup_date'].std()\n        df['signup_date'] = df['signup_date'].apply(lambda x: mean - 3 * std if x < mean - 3 * std else mean + 3 * std if x > mean + 3 * std else x)\n    \n    return df",
  "confidence": 0.9
}
